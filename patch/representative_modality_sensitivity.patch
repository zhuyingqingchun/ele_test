+#!/usr/bin/env bash

+set -euo pipefail

+

+PYTHON_PATH="${PYTHON_PATH:-python3}"

+DEVICE="${DEVICE:-cuda}"

+CUDA_VISIBLE_DEVICES="${CUDA_VISIBLE_DEVICES:-0}"

+

+PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"

+cd "${PROJECT_ROOT}"

+

+export PYTHONUNBUFFERED=1

+export PYTHONPATH=.

+export CUDA_VISIBLE_DEVICES

+

+DATASET="${DATASET:-${PROJECT_ROOT}/derived_datasets/servo_multimodal_handoff_dataset.npz}"

+CHECKPOINT="${CHECKPOINT:-${PROJECT_ROOT}/experiments_smoke_20260316/models/exp1_decoupled_v3_modality_tf_control/stage2_signal_fusion/best.pt}"

+OUTPUT_DIR="${OUTPUT_DIR:-${PROJECT_ROOT}/experiments_smoke_20260316/models/representative_modality_sensitivity}"

+BATCH_SIZE="${BATCH_SIZE:-32}"

+SEED="${SEED:--1}"

+SCENARIOS="${SCENARIOS:-bearing_defect,inverter_voltage_loss,thermal_saturation}"

+EXPECTED_KEY_MODALITIES="${EXPECTED_KEY_MODALITIES:-bearing_defect:vibration,inverter_voltage_loss:electrical,thermal_saturation:thermal}"

+

+if [[ ! -f "${CHECKPOINT}" ]]; then

+  echo "Missing checkpoint: ${CHECKPOINT}" >&2

+  echo "Please set CHECKPOINT=/path/to/best.pt before running." >&2

+  exit 1

+fi

+

+"${PYTHON_PATH}" experiments_smoke_20260316/eval_representative_modality_sensitivity.py \

+  --dataset "${DATASET}" \

+  --checkpoint "${CHECKPOINT}" \

+  --output-dir "${OUTPUT_DIR}" \

+  --device "${DEVICE}" \

+  --batch-size "${BATCH_SIZE}" \

+  --seed "${SEED}" \

+  --scenarios "${SCENARIOS}" \

+  --expected-key-modalities "${EXPECTED_KEY_MODALITIES}" \

+  "$@"

