+def _export_modality_mechanism_alignment_analysis(
+    output_dir: Path,
+    test_results: dict,
+    class_names: np.ndarray,
+) -> None:
+    scores = np.asarray(test_results.get("mechanism_scores", []), dtype=np.float32)
+    targets = np.asarray(test_results.get("targets", []), dtype=np.int64)
+    if scores.size == 0:
+        return
+    summary = {"branch_names": BRANCH_NAMES, "overall_hit_rate": 0.0, "per_class": {}}
+    hits = []
+    for i, target in enumerate(targets.tolist()):
+        class_name = str(class_names[target]).lower()
+        allowed = set(SUPPORT_MODALITIES_BY_SCENARIO.get(class_name, []))
+        primary = PRIMARY_MODALITY_BY_SCENARIO.get(class_name, "balanced")
+        if primary in BRANCH_NAMES:
+            allowed.add(primary)
+        top_modality = BRANCH_NAMES[int(scores[i].argmax())]
+        hits.append(int(top_modality in allowed))
+        bucket = summary["per_class"].setdefault(str(class_names[target]), {"sample_count": 0, "mean_score": [0.0] * len(BRANCH_NAMES)})
+        bucket["sample_count"] += 1
+        for j in range(len(BRANCH_NAMES)):
+            bucket["mean_score"][j] += float(scores[i, j])
+    summary["overall_hit_rate"] = _mean_or_nan(hits)
+    for class_name, bucket in summary["per_class"].items():
+        bucket["mean_score"] = [v / max(bucket["sample_count"], 1) for v in bucket["mean_score"]]
+        bucket["top_modality"] = BRANCH_NAMES[int(np.argmax(np.asarray(bucket["mean_score"], dtype=np.float32)))]
+    summary_path = output_dir / "test_modality_mechanism_summary.json"
+    summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding="utf-8")
+    print(f"modality_mechanism_summary={summary_path}")
+
+
+def _export_contrast_rejection_analysis(
+    output_dir: Path,
+    test_results: dict,
+    class_names: np.ndarray,
+) -> None:
+    scores = np.asarray(test_results.get("contrast_scores", []), dtype=np.float32)
+    targets = np.asarray(test_results.get("targets", []), dtype=np.int64)
+    if scores.size == 0:
+        return
+    reject_hits = []
+    for i, target in enumerate(targets.tolist()):
+        class_name = str(class_names[target]).lower()
+        banned = set(SUPPORT_MODALITIES_BY_SCENARIO.get(class_name, []))
+        primary = PRIMARY_MODALITY_BY_SCENARIO.get(class_name, "balanced")
+        if primary in BRANCH_NAMES:
+            banned.add(primary)
+        top_modality = BRANCH_NAMES[int(scores[i].argmax())]
+        reject_hits.append(int(top_modality not in banned))
+    summary = {
+        "branch_names": BRANCH_NAMES,
+        "contrast_rejection_rate": _mean_or_nan(reject_hits),
+    }
+    summary_path = output_dir / "test_contrast_rejection_summary.json"
+    summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding="utf-8")
+    print(f"contrast_rejection_summary={summary_path}")
+
+
+def _export_vibration_branch_weight_analysis(
+    output_dir: Path,
+    test_results: dict,
+    class_names: np.ndarray,
+) -> None:
+    branch_weights = np.asarray(test_results.get("vibration_branch_weights", []), dtype=np.float32)
+    targets = np.asarray(test_results.get("targets", []), dtype=np.int64)
+    if branch_weights.size == 0:
+        return
+    branch_names = ["raw_time", "envelope", "time_frequency"]
+    summary = {"branch_names": branch_names, "per_class": {}}
+    for i, target in enumerate(targets.tolist()):
+        class_name = str(class_names[target])
+        bucket = summary["per_class"].setdefault(class_name, {"sample_count": 0, "mean_weight": [0.0, 0.0, 0.0]})
+        bucket["sample_count"] += 1
+        for j in range(3):
+            bucket["mean_weight"][j] += float(branch_weights[i, j])
+    for class_name, bucket in summary["per_class"].items():
+        bucket["mean_weight"] = [v / max(bucket["sample_count"], 1) for v in bucket["mean_weight"]]
+        bucket["dominant_branch"] = branch_names[int(np.argmax(np.asarray(bucket["mean_weight"], dtype=np.float32)))]
+    summary_path = output_dir / "test_vibration_branch_weight_summary.json"
+    summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding="utf-8")
+    print(f"vibration_branch_weight_summary={summary_path}")
+
+
+def _clone_with_zeroed_modality(batch: DecoupledBatch, modality_name: str) -> DecoupledBatch:
+    zeros = {
+        "pos": torch.zeros_like(batch.pos),
+        "electrical": torch.zeros_like(batch.electrical),
+        "thermal": torch.zeros_like(batch.thermal),
+        "vibration": torch.zeros_like(batch.vibration),
+    }
+    return DecoupledBatch(
+        pos=zeros["pos"] if modality_name == "position" else batch.pos,
+        electrical=zeros["electrical"] if modality_name == "electrical" else batch.electrical,
+        thermal=zeros["thermal"] if modality_name == "thermal" else batch.thermal,
+        vibration=zeros["vibration"] if modality_name == "vibration" else batch.vibration,
+        sample_index=batch.sample_index,
+        y_cls=batch.y_cls,
+    )
+
+
+def _export_counterfactual_modality_sensitivity(
+    model,
+    loader,
+    device: torch.device,
+    text_cache,
+    output_dir: Path,
+) -> None:
+    model.eval()
+    summary = {"modalities": {}}
+    with torch.no_grad():
+        for modality_name in BRANCH_NAMES:
+            total = 0
+            correct = 0
+            flip_count = 0
+            logit_drop_sum = 0.0
+            for batch in loader:
+                if isinstance(batch, tuple):
+                    batch, recs = batch
+                    idx = torch.as_tensor([int(r.index) for r in recs], dtype=torch.long)
+                    text_emb = _move_text_views_to_device(_select_all_text_views(text_cache, idx), device)
+                else:
+                    text_emb = None
+                batch = move_batch_to_device(batch, device)
+                base_outputs = model(batch, text_emb) if text_emb is not None else model(batch)
+                base_preds = base_outputs.logits.argmax(dim=1)
+                base_true_logits = base_outputs.logits.gather(1, batch.y_cls.unsqueeze(1)).squeeze(1)
+                masked_batch = _clone_with_zeroed_modality(batch, modality_name)
+                masked_outputs = model(masked_batch, text_emb) if text_emb is not None else model(masked_batch)
+                masked_preds = masked_outputs.logits.argmax(dim=1)
+                masked_true_logits = masked_outputs.logits.gather(1, batch.y_cls.unsqueeze(1)).squeeze(1)
+                total += int(batch.y_cls.numel())
+                correct += int((masked_preds == batch.y_cls).sum().item())
+                flip_count += int((masked_preds != base_preds).sum().item())
+                logit_drop_sum += float((base_true_logits - masked_true_logits).sum().item())
+            summary["modalities"][modality_name] = {
+                "masked_accuracy": correct / max(total, 1),
+                "prediction_flip_rate": flip_count / max(total, 1),
+                "mean_true_logit_drop": logit_drop_sum / max(total, 1),
+            }
+    summary_path = output_dir / "test_counterfactual_modality_sensitivity.json"
+    summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding="utf-8")
+    print(f"counterfactual_modality_sensitivity={summary_path}")

