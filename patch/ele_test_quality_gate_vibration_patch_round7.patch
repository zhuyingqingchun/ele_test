+BRANCH_NAMES = ["position", "electrical", "thermal", "vibration"]
+MECHANICAL_RELATED_FAMILIES = {"mechanical_fault", "friction_increase", "jam", "load_disturbance"}
+
+
+def _mean_or_nan(values: list[float]) -> float:
+    return float(sum(values) / len(values)) if values else float("nan")
+
+
+def _summarize_gate_rows(rows: list[dict[str, Any]]) -> dict[str, Any]:
+    if not rows:
+        return {"num_samples": 0}
+    gate_means = {
+        branch: _mean_or_nan([float(row[f"{branch}_gate"]) for row in rows])
+        for branch in BRANCH_NAMES
+    }
+    energy_means = {
+        branch: _mean_or_nan([float(row[f"{branch}_energy"]) for row in rows])
+        for branch in BRANCH_NAMES
+    }
+    top_gate_counts = {branch: 0 for branch in BRANCH_NAMES}
+    for row in rows:
+        top_branch = max(BRANCH_NAMES, key=lambda branch: float(row[f"{branch}_gate"]))
+        top_gate_counts[top_branch] += 1
+    num_samples = len(rows)
+    return {
+        "num_samples": num_samples,
+        "gate_means": gate_means,
+        "energy_means": energy_means,
+        "top_gate_counts": top_gate_counts,
+        "top_gate_fraction": {branch: float(count / num_samples) for branch, count in top_gate_counts.items()},
+        "vibration_top_gate_fraction": float(top_gate_counts["vibration"] / num_samples),
+    }
+
+
+def export_quality_gate_artifacts(
+    output_dir: Path,
+    split_name: str,
+    metrics: dict[str, Any],
+    class_names: np.ndarray,
+) -> dict[str, str]:
+    gates = metrics.get("quality_gates") or []
+    if not gates:
+        return {}
+    energies = metrics.get("branch_energies") or []
+    sample_indices = metrics.get("sample_indices") or []
+    predictions = metrics.get("predictions") or []
+    targets = metrics.get("targets") or []
+    class_name_list = [str(item) for item in class_names.astype(str).tolist()]
+
+    rows: list[dict[str, Any]] = []
+    for i, gate_row in enumerate(gates):
+        energy_row = energies[i] if i < len(energies) else [float("nan")] * len(BRANCH_NAMES)
+        target_idx = int(targets[i])
+        pred_idx = int(predictions[i])
+        target_name = class_name_list[target_idx]
+        pred_name = class_name_list[pred_idx]
+        target_family = FAMILY_BY_SCENARIO.get(target_name, "unknown")
+        pred_family = FAMILY_BY_SCENARIO.get(pred_name, "unknown")
+        row: dict[str, Any] = {
+            "sample_index": int(sample_indices[i]) if i < len(sample_indices) else i,
+            "target_idx": target_idx,
+            "target_scenario": target_name,
+            "target_family": target_family,
+            "pred_idx": pred_idx,
+            "pred_scenario": pred_name,
+            "pred_family": pred_family,
+            "mechanical_related": int(target_family in MECHANICAL_RELATED_FAMILIES),
+        }
+        for branch, gate_value, energy_value in zip(BRANCH_NAMES, gate_row, energy_row):
+            row[f"{branch}_gate"] = float(gate_value)
+            row[f"{branch}_energy"] = float(energy_value)
+        rows.append(row)
+
+    csv_path = output_dir / f"{split_name}_quality_gates.csv"
+    with csv_path.open("w", encoding="utf-8", newline="") as f:
+        writer = csv.DictWriter(f, fieldnames=list(rows[0].keys()))
+        writer.writeheader()
+        writer.writerows(rows)
+
+    class_summary = {
+        class_name: _summarize_gate_rows([row for row in rows if row["target_scenario"] == class_name])
+        for class_name in sorted({str(row["target_scenario"]) for row in rows})
+    }
+    family_summary = {
+        family_name: _summarize_gate_rows([row for row in rows if row["target_family"] == family_name])
+        for family_name in sorted({str(row["target_family"]) for row in rows})
+    }
+    mechanical_rows = [row for row in rows if row["target_family"] in MECHANICAL_RELATED_FAMILIES]
+    non_mechanical_rows = [row for row in rows if row["target_family"] not in MECHANICAL_RELATED_FAMILIES]
+    summary = {
+        "split": split_name,
+        "branch_names": BRANCH_NAMES,
+        "mechanical_related_families": sorted(MECHANICAL_RELATED_FAMILIES),
+        "overall": _summarize_gate_rows(rows),
+        "mechanical_related": _summarize_gate_rows(mechanical_rows),
+        "non_mechanical": _summarize_gate_rows(non_mechanical_rows),
+        "by_true_family": family_summary,
+        "by_true_class": class_summary,
+    }
+    summary_path = output_dir / f"{split_name}_quality_gate_summary.json"
+    summary_path.write_text(json.dumps(summary, ensure_ascii=False, indent=2), encoding="utf-8")
+    return {"csv": str(csv_path), "summary_json": str(summary_path)}
